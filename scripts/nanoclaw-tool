        "gsd": cmd_gsd,
        "propose": cmd_propose,
        "identity": cmd_identity,
        "autoresearch": cmd_autoresearch,
        "stream": cmd_stream,
        "gmail": cmd_gmail,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
