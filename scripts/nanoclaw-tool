    args = parser.parse_args()

    commands = {
        "send": cmd_send,
        "react": cmd_react,
        "learn": cmd_learn,
        "task": cmd_task,
        "search": cmd_search,
        "schedule": cmd_schedule,
        "file": cmd_file,
        "groups": cmd_groups,
        "items": cmd_items,
        "index": cmd_index,
        "spawn-team": cmd_spawn_team,
