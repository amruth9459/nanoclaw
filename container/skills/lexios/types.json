{
  "_meta": {
    "version": 1,
    "total_types": 101,
    "domains": ["architectural", "structural", "mep", "schedule_admin", "site_civil"],
    "tiers": {
      "quick": "Core types extracted in every run (~9 types, ~$0.50)",
      "standard": "Extended types for thorough analysis (~30 types, ~$2.00)",
      "comprehensive": "All types for full document intelligence (~97 types, ~$5.00)"
